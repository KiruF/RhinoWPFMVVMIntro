<UserControl x:Class="RhinoWPFMVVVMIntro.Views.HostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:RhinoWPFMVVVMIntro.ViewModels"
             xmlns:views="clr-namespace:RhinoWPFMVVVMIntro.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="400"
             d:DataContext="{d:DesignInstance 
        Type=vm:HostVM,
        IsDesignTimeCreatable=False}">

    <Grid Margin="12">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Padding="8,4"
                       Text="{Binding Counter}" />

            <Button Padding="8,4"
                    Command="{Binding SelectAllRhObjs}"
                    Content="Select all rhino objects"/>

            <Button Padding="8,4"
                    Command="{Binding ScaleSelectedRhObjs}"
                    Content="scale selected rhino objects" />

             <Button Padding="8,4"
                    Command="{Binding MoveAwaySelectedRhObjs}"
                    Content="Move away selected rhino object" />

            <views:LayerAssignmentView />

        </StackPanel>
    </Grid>
</UserControl>
